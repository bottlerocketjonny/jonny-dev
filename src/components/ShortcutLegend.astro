---
const shortcuts = [
  { keys: ['j', 'k'], hint: 'step through sections' },
  { keys: ['1', '—', '4'], hint: 'jump to a section' },
  { keys: ['?'], hint: 'this panel' },
  { keys: ['esc'], hint: 'close' },
];
---
<div class="keys-hint-wrap">
  <button
    class="keys-hint mono"
    id="keysHint"
    type="button"
    aria-expanded="false"
    aria-controls="shortcutLegend"
    aria-label="Show keyboard shortcuts"
  >
    <span aria-hidden="true">?</span>
    <span class="keys-hint-text">shortcuts</span>
  </button>
  <span
    class="keys-prompt"
    id="keysPrompt"
    role="note"
    hidden
    aria-hidden="true"
  >try <kbd>j</kbd> <kbd>k</kbd> <kbd>?</kbd></span>
</div>

<aside
  class="legend"
  id="shortcutLegend"
  role="region"
  aria-labelledby="legendTitle"
  hidden
>
  <header class="legend-head">
    <h3 id="legendTitle" class="legend-title mono">Keyboard</h3>
    <button
      type="button"
      class="legend-close mono"
      id="legendClose"
      aria-label="Close keyboard shortcuts"
    >close ×</button>
  </header>
  <dl class="legend-list">
    {shortcuts.map((s) => (
      <div class="legend-row">
        <dt class="legend-keys">
          {s.keys.map((k, i) => (
            <>
              {i > 0 && k !== '—' && <span class="legend-sep" aria-hidden="true"> </span>}
              {k === '—' ? (
                <span class="legend-range" aria-hidden="true">—</span>
              ) : (
                <kbd class="legend-key">{k}</kbd>
              )}
            </>
          ))}
        </dt>
        <dd class="legend-hint">{s.hint}</dd>
      </div>
    ))}
  </dl>
</aside>

<style>
  .keys-hint-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .keys-hint {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--muted);
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 10px 4px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .keys-hint:hover,
  .keys-hint[aria-expanded="true"] {
    color: var(--ink);
    border-color: var(--muted);
  }
  .keys-hint[aria-expanded="true"] {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* first-visit microcopy — lives below the header rule so it doesn't
     crash into the line, right-aligned to the pill so it reads as a
     footnote on the shortcuts affordance. serif italic, quiet. */
  .keys-prompt {
    position: absolute;
    top: calc(100% + 1.9rem);
    right: 0;
    white-space: nowrap;
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: 0.8rem;
    line-height: 1;
    color: var(--muted);
    opacity: 0;
    transform: translateY(-3px);
    transition: opacity 0.45s ease 0.2s, transform 0.45s ease 0.2s;
    pointer-events: none;
  }
  .keys-prompt[data-visible="true"] {
    opacity: 0.75;
    transform: translateY(0);
  }
  .keys-prompt kbd {
    font-family: 'JetBrains Mono', monospace;
    font-style: normal;
    font-size: 0.65rem;
    color: var(--accent-warm);
    padding: 0 0.1em;
  }

  .legend {
    position: fixed;
    bottom: clamp(1rem, 3vw, 1.75rem);
    right: clamp(1rem, 3vw, 1.75rem);
    z-index: 50;
    width: min(260px, calc(100vw - 2rem));
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: 1rem 1.1rem 1.1rem;
    box-shadow: 0 10px 30px -15px color-mix(in oklab, var(--ink) 30%, transparent);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .legend:not([hidden]) {
    opacity: 1;
    transform: translateY(0);
  }
  .legend[hidden] {
    display: block;
    pointer-events: none;
    visibility: hidden;
  }

  .legend-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    padding-bottom: 0.6rem;
    margin-bottom: 0.6rem;
    border-bottom: 1px solid var(--rule);
  }
  .legend-title {
    margin: 0;
    color: var(--ink);
    font-size: 10px;
  }
  .legend-close {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0;
    transition: color 0.3s ease;
  }
  .legend-close:hover {
    color: var(--ink);
  }

  .legend-list {
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.55rem;
  }
  .legend-row {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }
  .legend-keys {
    margin: 0;
    display: inline-flex;
    gap: 0.3rem;
    align-items: baseline;
  }
  .legend-key {
    font-family: 'JetBrains Mono', monospace;
    font-style: italic;
    color: var(--accent-warm);
    font-size: 12px;
    font-weight: 400;
  }
  .legend-range {
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
  }
  .legend-sep {
    width: 2px;
  }
  .legend-hint {
    margin: 0;
    font-size: 11px;
    color: var(--muted);
    line-height: 1.5;
  }

  .keys-hint:focus-visible,
  .legend-close:focus-visible {
    outline: 2px solid var(--accent-warm);
    outline-offset: 2px;
  }

  /* keyboard shortcuts are meaningless on touch — hide the affordance
     entirely so the header stays editorial and uncluttered on phones */
  @media (max-width: 900px) {
    .keys-hint-wrap {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .legend {
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
      width: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .legend,
    .keys-prompt {
      transition: none;
    }
  }
</style>

<script>
  const SECTIONS = ['hero', 'work', 'contributions', 'contact'];
  const SECTION_KEYS: Record<string, string> = {
    '1': SECTIONS[0],
    '2': SECTIONS[1],
    '3': SECTIONS[2],
    '4': SECTIONS[3],
  };

  const prefersReducedMotion =
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const sectionEls = SECTIONS.map((id) => document.getElementById(id)).filter(
    (el): el is HTMLElement => el !== null,
  );

  // The rail owns its own observer for the visible active state. For j/k we
  // track the most recently commanded or observed section in a local ref so
  // short pages (where the target can't scroll-to-top) don't stall the step.
  let currentSection = SECTIONS[0];
  let commandedUntil = 0;

  if (sectionEls.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (performance.now() < commandedUntil) return;
        const hits = entries.filter((e) => e.isIntersecting);
        if (hits.length === 0) return;
        hits.sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        const id = (hits[0].target as HTMLElement).id;
        if (id) currentSection = id;
      },
      {
        rootMargin: '-20% 0px -60% 0px',
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );
    sectionEls.forEach((el) => observer.observe(el));
  }

  const scrollToEl = (el: HTMLElement) => {
    el.scrollIntoView({
      behavior: prefersReducedMotion ? 'auto' : 'smooth',
      block: 'start',
    });
  };

  const scrollToSection = (id: string) => {
    const el = document.getElementById(id);
    if (!el) return;
    scrollToEl(el);
    currentSection = id;
    commandedUntil = performance.now() + 1500;
  };

  const step = (dir: 1 | -1) => {
    const idx = SECTIONS.indexOf(currentSection);
    const safeIdx = idx === -1 ? 0 : idx;
    const next = Math.max(0, Math.min(SECTIONS.length - 1, safeIdx + dir));
    scrollToSection(SECTIONS[next]);
  };

  const hint = document.getElementById('keysHint');
  const legend = document.getElementById('shortcutLegend');
  const legendClose = document.getElementById('legendClose');
  const prompt = document.getElementById('keysPrompt');

  // first-visit prompt — editorial footnote pointing at the shortcuts pill,
  // shown once per browser and dismissed on first interaction. Stored flag
  // survives a reload so the nudge never reappears.
  const PROMPT_KEY = 'jd:keys-seen';
  let promptHideTimer: number | null = null;
  const dismissPrompt = () => {
    if (!prompt) return;
    try { localStorage.setItem(PROMPT_KEY, '1'); } catch { /* ignore */ }
    if (prompt.dataset.visible !== 'true') return;
    prompt.dataset.visible = 'false';
    if (promptHideTimer !== null) {
      window.clearTimeout(promptHideTimer);
      promptHideTimer = null;
    }
    window.setTimeout(() => { prompt.hidden = true; }, 450);
  };
  if (prompt) {
    let seen = false;
    try { seen = localStorage.getItem(PROMPT_KEY) === '1'; } catch { /* ignore */ }
    if (!seen) {
      window.setTimeout(() => {
        prompt.hidden = false;
        // next frame so the transition registers
        requestAnimationFrame(() => { prompt.dataset.visible = 'true'; });
        // auto-retire after 8s even if the user never interacts
        promptHideTimer = window.setTimeout(dismissPrompt, 8000);
      }, 1400);
    }
  }

  const isLegendOpen = () => legend !== null && !legend.hidden;

  const openLegend = () => {
    if (!legend || !hint) return;
    legend.hidden = false;
    hint.setAttribute('aria-expanded', 'true');
    legendClose?.focus();
  };

  const closeLegend = () => {
    if (!legend || !hint) return;
    const returnFocus = document.activeElement === legendClose;
    legend.hidden = true;
    hint.setAttribute('aria-expanded', 'false');
    if (returnFocus) hint.focus();
  };

  const toggleLegend = () => {
    if (isLegendOpen()) closeLegend();
    else openLegend();
  };

  hint?.addEventListener('click', () => {
    dismissPrompt();
    toggleLegend();
  });
  legendClose?.addEventListener('click', closeLegend);
  document.addEventListener('click', (e) => {
    if (!isLegendOpen()) return;
    const target = e.target as Node | null;
    if (!target) return;
    if (legend?.contains(target)) return;
    if (hint?.contains(target)) return;
    closeLegend();
  });

  const isEditable = (el: Element | null): boolean => {
    if (!el) return false;
    const tag = el.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return true;
    if (el instanceof HTMLElement && el.isContentEditable) return true;
    return false;
  };

  window.addEventListener('keydown', (e) => {
    if (isEditable(document.activeElement)) return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;

    const key = e.key;

    // any shortcut keypress retires the first-visit prompt
    if (key === 'j' || key === 'k' || key === '?' || key === 'Escape' || SECTION_KEYS[key]) {
      dismissPrompt();
    }

    if (key === 'Escape') {
      if (isLegendOpen()) {
        e.preventDefault();
        closeLegend();
      }
      return;
    }

    if (key === '?') {
      e.preventDefault();
      toggleLegend();
      return;
    }

    if (key === 'j') {
      e.preventDefault();
      step(1);
      return;
    }
    if (key === 'k') {
      e.preventDefault();
      step(-1);
      return;
    }

    const sectionId = SECTION_KEYS[key];
    if (sectionId) {
      e.preventDefault();
      scrollToSection(sectionId);
    }
  });
</script>

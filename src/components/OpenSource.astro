---
import { site } from '../data/site.ts';

const isReal = (href?: string) => !!href && /^https?:/.test(href);
---
<section aria-labelledby="open-source" id="contributions">
  <h2 id="open-source" class="section-label mono" data-reveal>
    <span>{site.open_source_label}</span>
  </h2>
  <ul class="contrib-list">
    {site.open_source.map((c) => (
      <li class="contrib" data-reveal>
        {isReal(c.href) ? (
          <a class="contrib-link" href={c.href} rel="noopener noreferrer" target="_blank">
            <em class="contrib-label">{c.label}</em>
            <span class="contrib-sep" aria-hidden="true"> — </span>
            <span class="contrib-note">{c.note}</span>
            <span class="contrib-arrow" aria-hidden="true"> ↗</span>
          </a>
        ) : (
          <>
            <em class="contrib-label">{c.label}</em>
            <span class="contrib-sep" aria-hidden="true"> — </span>
            <span class="contrib-note">{c.note}</span>
          </>
        )}
      </li>
    ))}
  </ul>
</section>

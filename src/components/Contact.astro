---
import { site } from '../data/site.ts';
---
<section class="contact" id="contact" aria-labelledby="contact-label">
  <h2 id="contact-label" class="section-label mono">
    <span>Contact</span>
    <span>GMT / BST</span>
  </h2>
  <a class="contact-email" href={`mailto:${site.footer_left}`}>{site.footer_left}</a>
  <p class="contact-note">
    Always happy to chat — drop a line anytime.
  </p>
</section>

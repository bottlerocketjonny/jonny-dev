---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const linkLabel = data.link_label ?? 'source';
---
{data.link ? (
  <a class="project" href={data.link} rel="noopener noreferrer" target="_blank">
    <div class="meta-row">
      <span class="context">{data.context}</span>
      <span class="year">{data.year}</span>
    </div>
    <h3 class="title"><em>{data.accent}.</em>{data.title && <>{' '}{data.title}</>}</h3>
    <div class="desc"><Content /></div>
    <div class="stack mono">
      {data.stack.map((s) => <span>{s}</span>)}
    </div>
    <div class="affordance mono" aria-hidden="true">
      <span>{linkLabel} ↗</span>
    </div>
  </a>
) : (
  <article class="project project--private">
    <div class="meta-row">
      <span class="context">{data.context}</span>
      <span class="year">{data.year}</span>
    </div>
    <h3 class="title"><em>{data.accent}.</em>{data.title && <>{' '}{data.title}</>}</h3>
    <div class="desc"><Content /></div>
    <div class="stack mono">
      {data.stack.map((s) => <span>{s}</span>)}
    </div>
    <div class="affordance mono">
      <span>private — available on request</span>
    </div>
  </article>
)}
